# eslint-plugin-jsx-a11y@6.10.2's peerDependencies only list ESLint up to ^9
# (https://github.com/jsx-eslint/eslint-plugin-jsx-a11y) - it runs fine
# against ESLint 10 in practice (verified when it was added), the peer
# range is just stale. Without this, a plain `npm install`/`npm ci` fails
# outright with ERESOLVE for every contributor and in CI.
legacy-peer-deps=true
