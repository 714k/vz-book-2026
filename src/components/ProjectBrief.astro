---
import BackToTop from './BackToTop.astro';
import BriefField from './BriefField.astro';
import BriefList from './BriefList.astro';
import SuggestedDiagrams from './SuggestedDiagrams.astro';

interface BriefData {
  title: string;
  year?: string | number;
  timeline?: string;
  role?: string;
  company: string;
  industry: string;
  work: string;
  scope?: string;
  problem?: string;
  key_challenges?: string[];
  product_team?: string[];
  product_team_text?: string;
  key_contributions?: string[];
  technical_focus?: string[];
  suggested_diagrams?: string;
  suggested_diagrams_charts?: string[];
  system_impact?: string[];
  learnings?: string[];
  technologies: string[];
  status?: string;
  links?: Array<{
    href: string;
    title: string;
    text: string;
  }>;
  apps?: Array<{
    href: string;
    title: string;
    text: string;
  }>;
}

interface Props {
  data: BriefData;
}

const {
  role,
  company,
  timeline,
  scope,
  problem,
  product_team,
  product_team_text,
  key_challenges,
  key_contributions,
  technical_focus,
  suggested_diagrams,
  suggested_diagrams_charts,
  system_impact,
  learnings,
} = Astro.props.data;
---

<section>
  <BriefField title="Role" property={role} />
  <BriefField title="Company" property={company} />
  <BriefField title="Timeline" property={timeline} />
  <BriefField title="Scope" property={scope} />
  <BriefField title="Problem" property={problem} />
  <BriefList title="Product Team" text={product_team_text} items={product_team} />
  <BriefList title="Key Challenges" items={key_challenges} />
  <BriefList title="Key Contributions" items={key_contributions} />
  <BriefList title="Technical Focus" items={technical_focus} />
  <BriefField title="Suggested Diagrams" property={suggested_diagrams} />
  <SuggestedDiagrams diagrams={suggested_diagrams_charts} />
  <BriefList title="System Impact" items={system_impact} />
  <BriefField title="What I Learned" property={learnings} />
</section>

<BackToTop />

<style>
  section {
    padding: 0 20px 40px 20px;
  }
</style>
