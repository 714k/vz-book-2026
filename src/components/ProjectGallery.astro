---
import NavigationLinks from './NavigationLinks.astro';
import BackToTop from './BackToTop.astro';

interface Gallery {
  title: string;
}

interface GalleryImage {
  links: Array<{
    href: string;
    text: string;
    title: string;
  }>;
}

interface ProjectsNavigation {
  current: string;
}

interface Props {
  galleries: Gallery[];
  galleriesImages: GalleryImage[];
  projectsNavigation: ProjectsNavigation;
}

const { galleries, galleriesImages, projectsNavigation } = Astro.props;
const links = galleriesImages[0]?.links || [];
---

<section id="gallery">
  {
    galleries.map((gallery) => (
      <div id={`gallery-${gallery.title.toLowerCase()}`} class="gallery">
        <h2>{gallery.title} Gallery</h2>
        {links.map((link) => {
          const projectSlug = projectsNavigation.current.split(' ').join('-').toLowerCase();
          return (
            <figure id={`image-${gallery.title.toLowerCase()}-${link.text}`}>
              <span class="decorative device">
                <img
                  src={`/assets/images/projects/${projectSlug}-${gallery.title.toLowerCase()}-${link.text}.jpg`}
                  alt={`${gallery.title} gallery #${link.text}`}
                  width="100%"
                  height="auto"
                />
              </span>
              <br />

              <NavigationLinks
                classes="images-links"
                links={links}
                id={link}
                type="image"
                gallery={gallery}
              />
            </figure>
          );
        })}

        <BackToTop />
      </div>
    ))
  }
</section>
