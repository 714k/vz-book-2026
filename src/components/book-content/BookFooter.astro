---
// Page-level metadata for the article, rendered as a <footer> with a <dl>,
// followed by the sources the copy cites. Only provided fields render.
import type { FooterMeta } from './types';

type Props = FooterMeta;

const { sectionTitle, pageTitle, fileId, version, lastUpdated, author, role, references } =
  Astro.props;

const items = [
  { term: 'Section', value: sectionTitle },
  { term: 'Page', value: pageTitle },
  { term: 'File ID', value: fileId },
  { term: 'Version', value: version },
  { term: 'Last Updated', value: lastUpdated },
  { term: 'Author', value: author },
  { term: 'Role', value: role },
].filter((item) => Boolean(item.value));
---

<footer class="book-footer">
  <dl>
    {
      items.map((item) => (
        <div>
          <dt>{item.term}</dt>
          <dd>{item.value}</dd>
        </div>
      ))
    }
  </dl>

  {
    references && references.length > 0 && (
      <>
        <h2>References</h2>
        <ol class="book-footer-references">
          {references.map((reference) => (
            <li id={`reference-${reference.marker}`}>
              <a href={reference.href}>{reference.title}</a>
            </li>
          ))}
        </ol>
      </>
    )
  }
</footer>
