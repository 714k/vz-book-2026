---
interface Props {
  title: string;
  text?: string;
  items?: string[];
}

const { title, text, items } = Astro.props;
---

{
  (text || (items && items.length > 0)) && (
    <section>
      <h2>{title}</h2>
      {text && <p>{text}</p>}
      {items && items.length > 0 && (
        <ul>
          {items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      )}
    </section>
  )
}
