---
interface Props {
  diagrams?: string[];
}

const { diagrams } = Astro.props;
---

{
  diagrams && diagrams.length > 0 && (
    <div class="suggested-diagrams">
      {diagrams.map((diagram) => (
        <div class="diagram-viewer">
          <div class="diagram-viewer__controls">
            <button type="button" data-zoom-in aria-label="Zoom in">
              +
            </button>
            <button type="button" data-zoom-out aria-label="Zoom out">
              &minus;
            </button>
            <button type="button" data-zoom-reset aria-label="Reset zoom">
              &#8635;
            </button>
          </div>
          <div class="diagram-viewer__canvas">
            <pre class="mermaid">{diagram}</pre>
          </div>
        </div>
      ))}
    </div>
  )
}

<style>
  .suggested-diagrams {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .diagram-viewer {
    position: relative;
    border: 1px solid var(--color-secondary, #ccc);
    border-radius: 8px;
    overflow: hidden;
  }

  .diagram-viewer__canvas {
    height: 420px;
    width: 100%;
    touch-action: none;
  }

  .diagram-viewer__canvas :global(pre.mermaid) {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  .diagram-viewer__canvas :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none !important;
  }

  .diagram-viewer__controls {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 1;
    display: flex;
    gap: 4px;
  }

  .diagram-viewer__controls button {
    width: 32px;
    height: 32px;
    border: none;
    border-radius: 4px;
    background: var(--color-primary, #333);
    color: var(--color-secondary, #fff);
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
  }
</style>

<script>
  import mermaid from 'mermaid';
  import svgPanZoom from 'svg-pan-zoom';

  // Resolves any CSS color (hex, rgb, named) to its [r, g, b] channels by
  // letting the browser normalize it via computed style, since mermaid's
  // themeVariables need concrete color strings, not CSS custom properties.
  function toRgbChannels(color: string): [number, number, number] {
    const probe = document.createElement('div');
    probe.style.color = color;
    document.body.appendChild(probe);
    const computed = getComputedStyle(probe).color;
    probe.remove();
    const channels = computed.match(/\d+(\.\d+)?/g)?.map(Number) ?? [0, 0, 0];
    return [channels[0], channels[1], channels[2]];
  }

  // WCAG relative luminance / contrast ratio, used to pick whichever of
  // black or white reads better on a given project accent color.
  function contrastTextColor(color: string): string {
    const [r, g, b] = toRgbChannels(color);
    const channel = (c: number) => {
      const s = c / 255;
      return s <= 0.03928 ? s / 12.92 : Math.pow((s + 0.055) / 1.055, 2.4);
    };
    const luminance = 0.2126 * channel(r) + 0.7152 * channel(g) + 0.0722 * channel(b);
    const contrastWithWhite = 1.05 / (luminance + 0.05);
    const contrastWithBlack = (luminance + 0.05) / 0.05;
    return contrastWithWhite >= contrastWithBlack ? '#ffffff' : '#000000';
  }

  const rootStyles = getComputedStyle(document.documentElement);
  const primaryColor = rootStyles.getPropertyValue('--color-primary').trim() || '#333333';
  const secondaryColor = rootStyles.getPropertyValue('--color-secondary').trim() || '#111111';
  const onPrimary = contrastTextColor(primaryColor);
  const onSecondary = contrastTextColor(secondaryColor);

  mermaid.initialize({
    startOnLoad: false,
    theme: 'base',
    themeVariables: {
      background: 'transparent',
      primaryColor,
      primaryBorderColor: secondaryColor,
      primaryTextColor: onPrimary,
      lineColor: secondaryColor,
      secondaryColor,
      secondaryBorderColor: primaryColor,
      secondaryTextColor: onSecondary,
      tertiaryColor: primaryColor,
      tertiaryBorderColor: secondaryColor,
      tertiaryTextColor: onPrimary,
      actorBkg: primaryColor,
      actorBorder: secondaryColor,
      actorTextColor: onPrimary,
      actorLineColor: secondaryColor,
      signalColor: secondaryColor,
      signalTextColor: onSecondary,
      labelBoxBkgColor: primaryColor,
      labelBoxBorderColor: secondaryColor,
      labelTextColor: onPrimary,
      loopTextColor: onSecondary,
      noteBkgColor: secondaryColor,
      noteBorderColor: primaryColor,
      noteTextColor: onSecondary,
    },
  });

  async function setup() {
    await mermaid.run({ querySelector: '.mermaid' });

    document.querySelectorAll<HTMLElement>('.diagram-viewer').forEach((viewer) => {
      const svg = viewer.querySelector<SVGSVGElement>('svg');
      if (!svg) return;

      // Mermaid sizes the svg to its natural diagram dimensions and caps it
      // with an inline max-width; override both so the element actually
      // fills the fixed-height canvas before svg-pan-zoom measures it -
      // otherwise "fit" scales against the wrong (often much taller) box
      // and the rendered diagram overflows the visible canvas.
      svg.removeAttribute('width');
      svg.removeAttribute('height');
      svg.style.removeProperty('max-width');

      const panZoom = svgPanZoom(svg, {
        zoomEnabled: true,
        controlIconsEnabled: false,
        fit: true,
        center: true,
        minZoom: 0.5,
        maxZoom: 10,
      });

      panZoom.resize();
      panZoom.fit();
      panZoom.center();

      viewer.querySelector('[data-zoom-in]')?.addEventListener('click', () => panZoom.zoomIn());
      viewer.querySelector('[data-zoom-out]')?.addEventListener('click', () => panZoom.zoomOut());
      viewer.querySelector('[data-zoom-reset]')?.addEventListener('click', () => panZoom.reset());
    });
  }

  setup();
</script>
