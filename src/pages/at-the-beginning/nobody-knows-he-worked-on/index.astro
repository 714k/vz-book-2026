---
import BookPage from '../../../layouts/BookPage.astro';
import TOC from '../../../components/TOC.astro';
import ProjectSummary from '../../../components/ProjectSummary.astro';
import { getRequiredEntry } from '../../../lib/content';

const nobodyKnowsHeWorkedOn = (await getRequiredEntry('nobodyKnowsHeWorkedOn', 'data')).data;
---

<BookPage
  title="Nobody knows he worked on..."
  primaryColor="#ffff00"
  secondaryColor="#606200"
  previousPage="/at-the-beginning/no-one-knows/the-fixer"
  nextPage="/at-the-beginning/nobody-knows-he-worked-on/plastiq/"
  previousTitle="The Fixer"
  nextTitle="Plastiq"
  currentUrl={Astro.url.pathname}
>
  <header class="cover">
    <h1>Nobody knows he worked on...</h1>
  </header>
  <TOC data={nobodyKnowsHeWorkedOn.toc} />

  <ProjectSummary summaries={nobodyKnowsHeWorkedOn.summaries} />
</BookPage>
