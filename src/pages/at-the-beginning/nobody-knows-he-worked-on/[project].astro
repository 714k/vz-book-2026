---
import Default from '../../../layouts/Default.astro';
import Project from '../../../components/Project.astro';
import { getEntry } from 'astro:content';

interface ProjectEntry {
  slug: string;
  title: string;
  projectTitle?: string;
  primaryColor: string;
  secondaryColor: string;
  coverBg: string;
  projectBg: string;
}

// getStaticPaths() runs in an isolated scope, so all data it needs (besides
// module imports) must be declared inside it rather than in the frontmatter above.
export async function getStaticPaths() {
  const SECTION_URL = '/at-the-beginning/nobody-knows-he-worked-on';
  const SECTION_TITLE = 'Nobody knows he worked on...';
  const NEXT_SECTION_URL = '/at-the-beginning/nor-where-to-find-him/';
  const NEXT_SECTION_TITLE = 'Nor where to find him...';

  const plastiqEntry = await getEntry('projects', 'plastiq');
  const hboMaxEntry = await getEntry('projects', 'hbo-max');
  const hboEntry = await getEntry('projects', 'hbo');

  // Order drives prev/next navigation - keep in sync with the site's chronological project order.
  const projects: ProjectEntry[] = [
    {
      slug: 'plastiq',
      title: 'Plastiq',
      projectTitle: plastiqEntry?.data.brief.title,
      primaryColor: '#1daeec',
      secondaryColor: '#00255b',
      coverBg: '/assets/images/projects/plastiq-cover.jpg',
      projectBg: '/assets/images/projects/plastiq-bg.jpg',
    },
    {
      slug: 'hbo-max',
      title: 'HBO Max',
      projectTitle: hboMaxEntry?.data.brief.title,
      primaryColor: '#7752b1',
      secondaryColor: '#34106d',
      coverBg: '/assets/images/projects/hbomax-cover.jpg',
      projectBg: '/assets/images/projects/hbomax-bg.jpg',
    },
    {
      slug: 'hbo',
      title: 'HBO',
      projectTitle: hboEntry?.data.brief.title,
      primaryColor: '#2bb0d8',
      secondaryColor: '#00394b',
      coverBg: '/assets/images/projects/hbo-cover.jpg',
      projectBg: '/assets/images/projects/hbo-bg.jpg',
    },
    {
      slug: 'aeris',
      title: 'Aeris',
      primaryColor: '#067cfa',
      secondaryColor: '#002d5d',
      coverBg: '/assets/images/projects/aeris-cover.jpg',
      projectBg: '/assets/images/projects/aeris-bg.jpg',
    },
    {
      slug: 'citi-banamex',
      title: 'Citi Banamex',
      primaryColor: '#ed1c24',
      secondaryColor: '#630004',
      coverBg: '/assets/images/projects/citi-banamex-cover.jpg',
      projectBg: '/assets/images/projects/citi-banamex-bg.jpg',
    },
    {
      slug: 'johnson-and-johnson',
      title: 'Johnson & Johnson',
      primaryColor: '#f41e2e',
      secondaryColor: '#630008',
      coverBg: '/assets/images/projects/johnson-and-johnson-cover.jpg',
      projectBg: '/assets/images/projects/johnson-and-johnson-bg.jpg',
    },
    {
      slug: 'american-airlines',
      title: 'American Airlines',
      primaryColor: '#fff',
      secondaryColor: '#0078d2',
      coverBg: '/assets/images/projects/aa-cover.jpg',
      projectBg: '/assets/images/projects/aa-bg.jpg',
    },
  ];

  return projects.map((project, index) => {
    const previous = index > 0 ? projects[index - 1] : null;
    const next = index < projects.length - 1 ? projects[index + 1] : null;

    return {
      params: { project: project.slug },
      props: {
        project,
        previousPage: previous ? `${SECTION_URL}/${previous.slug}/` : `${SECTION_URL}/`,
        previousTitle: previous ? previous.title : SECTION_TITLE,
        nextPage: next ? `${SECTION_URL}/${next.slug}/` : NEXT_SECTION_URL,
        nextTitle: next ? next.title : NEXT_SECTION_TITLE,
      },
    };
  });
}

const { project, previousPage, previousTitle, nextPage, nextTitle } = Astro.props;
---

<Default
  title={project.title}
  primaryColor={project.primaryColor}
  secondaryColor={project.secondaryColor}
  classNames="project-n "
  coverBg={project.coverBg}
  projectBg={project.projectBg}
  previousPage={previousPage}
  nextPage={nextPage}
  previousTitle={previousTitle}
  nextTitle={nextTitle}
  currentUrl={Astro.url.pathname}
>
  <Project title={project.projectTitle ?? project.title} projectName={project.slug} />
</Default>
